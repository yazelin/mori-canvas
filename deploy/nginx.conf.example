# nginx 反向代理 — 內網用,前面終結 TLS,後面是 loopback 的 mori-canvas-server。
# binary 已內嵌前端(頁面 + /api + /sync 全在同一個 port),所以不需要 root 指 dist:
# 全部 proxy 給 127.0.0.1:1334(= deploy/mori-canvas.service 預設的 PORT/BIND)即可。

server {
    listen 443 ssl;
    server_name whiteboard.your-internal-domain;     # 或內網 IP

    ssl_certificate     /etc/ssl/whiteboard/cert.pem;  # 你的正式/內網憑證
    ssl_certificate_key /etc/ssl/whiteboard/key.pem;

    # --- 只開放內網(照你的 LAN 調整) ---
    allow 192.168.0.0/16;
    allow 10.0.0.0/8;
    deny  all;

    # --- 頁面(binary 內嵌的前端) ---
    location / {
        proxy_pass http://127.0.0.1:1334;
    }

    # --- API -> loopback 的 server ---
    location /api/ {
        proxy_pass http://127.0.0.1:1334;
        client_max_body_size 25m;            # 語音上傳
    }

    # --- 同步 websocket -> loopback 的 server ---
    location /sync/ {
        proxy_pass http://127.0.0.1:1334;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 1h;               # 長連線不要被收掉
    }
}

# 前端走 same-origin(/api、/sync),所以分享/QR 網址自動就是這個 nginx 網域 —
# app 裡什麼都不用設。手機錄音需要 HTTPS,這裡由 nginx 提供,server 留 HTTP loopback。
