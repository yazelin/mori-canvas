# /etc/mori-canvas.env — mori-canvas.service 的 EnvironmentFile。
# 複製過去後填值;含 key,權限建議 600(sudo chmod 600 /etc/mori-canvas.env)。

# AI(逐字稿 → 便利貼)的 Groq key。執行身分的 ~/.mori/config.json 有 key 的話可不填。
GROQ_API_KEY=gsk_xxxxxxxx

# 監聽 port(預設 1334;nginx.conf.example 的 proxy_pass 指這裡)
PORT=1334

# 綁定位址:nginx 在前面就維持 loopback;純內網直連(不擺 nginx)改 0.0.0.0
BIND=127.0.0.1

# 主機設定的鎖:設了之後改主機級設定(whisperUrl / 模式 / 本機模式 / 主機 Groq key)
# 與「結束房間」要帶相符的 X-Admin-Token header,否則 401。
# 注意:nginx 在同一台主機上反代時,所有訪客的來源看起來都是 loopback,
# 沒設的話人人都改得動主機設定 —— 這種部署一定要設,用一串長隨機字串。
ADMIN_TOKEN=use-a-long-random-string

# 資料不出網:AI 只走本機 Ollama、封鎖雲端 STT 與訪客 BYO,設定頁關不掉
# LLM_LOCAL_ONLY=1

# 自帶 TLS(不擺 nginx 又要手機錄音時):certs/ 相對 WorkingDirectory,先跑 setup.sh 產憑證
# HTTPS=1
