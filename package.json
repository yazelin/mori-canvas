{
  "name": "mori-canvas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "FOSS twin of tldraw-agent-spike: a server-side bot draws into a self-hosted yjs (y-websocket) room, rendered on a Konva canvas. Zero-license-cost stack — sellable.",
  "scripts": {
    "build:client": "vite build",
    "build": "vite build && cargo build --release --manifest-path server-rs/Cargo.toml",
    "start": "./server-rs/target/release/mori-canvas-server",
    "start:lan": "HTTPS=1 PORT=5174 BIND=0.0.0.0 ./server-rs/target/release/mori-canvas-server",
    "dev": "cargo build --manifest-path server-rs/Cargo.toml && ./server-rs/target/debug/mori-canvas-server",
    "tauri": "cargo build --manifest-path src-tauri/Cargo.toml && ./src-tauri/target/debug/mori-canvas-app",
    "setup": "bash setup.sh"
  },
  "dependencies": {
    "i18next": "^26.3.1",
    "konva": "^10.3.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-konva": "^19.2.4",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
