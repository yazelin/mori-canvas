# Mori Canvas — environment variables.
# DO NOT put real secrets in git. On Render, set these in the dashboard (Environment).
# For local use you may copy this to .env (already gitignored) — but locally the Groq key
# is usually read from ~/.mori/config.json already, so you don't even need this.

# REQUIRED for cloud deploy — your Groq API key.
# Use a DEDICATED demo key and set a SPENDING CAP on it in the Groq console.
GROQ_API_KEY=gsk_xxxxxxxx_put_it_in_the_render_dashboard_not_here

# Privacy: lock local-only mode at boot ("1" or "true"). AI goes local Ollama only,
# cloud Groq Whisper and visitor BYO (X-LLM-Base) endpoints are refused, and the
# settings page/API cannot turn it off. Pair with a local whisper-server for STT.
# LLM_LOCAL_ONLY=1

# Demo guards (optional)
DEMO_RATE_PER_MIN=60

# Room governance (optional; all default to "off" for self-hosting)
# ROOM_TTL_HOURS: rooms idle longer than this are unloaded and their .data/<room>.bin
#   deleted (background sweep every 30 min). 0 = keep forever. DEMO room is exempt.
# MAX_ROOMS: refuse creating NEW rooms beyond this count (existing rooms still open). 0 = unlimited.
# PUBLIC_ROOM_LIST: set to 0 to make GET /api/rooms return only {count} without room codes
#   (a room code is the key to enter — on a public demo, don't list it). Unset/1 = list as before.
# ROOM_TTL_HOURS=72
# MAX_ROOMS=200
# PUBLIC_ROOM_LIST=0
SPONSOR_URL=https://your-sponsor-or-portfolio-link
SPONSOR_LABEL=贊助
DEMO_NOTICE=試玩版:AI 由站長 API 處理請手下留情;資料不會永久保存,想留著請用「匯出→下載畫板檔」

# Deploy: Render injects PORT automatically; bind all interfaces. TLS is at the edge,
# so DO NOT set HTTPS on Render. (HTTPS=1 + certs/ is only for self-hosted LAN.)
# BIND=0.0.0.0
